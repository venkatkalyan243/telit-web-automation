<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Telit - Regression Suite"
       parallel="methods"
       thread-count="2"
       verbose="1">

  <listeners>
    <listener class-name="com.telit.listener.RetryListener"/>
    <listener class-name="com.telit.listener.TestListener"/>
  </listeners>

  <test name="Login &amp; Authentication Regression">
    <classes>
      <class name="com.telit.test.login.LoginTest"/>
    </classes>
  </test>
</suite>
